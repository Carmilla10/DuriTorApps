<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Left Column: Image + View Text -->
        <LinearLayout
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <ImageView
                android:id="@+id/historyImage"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:background="#F0F0F0"
                android:clickable="true"
                android:contentDescription="@string/view_image"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_camera"
                app:cardCornerRadius="8dp" />

            <!-- Added View Image label with its own ID -->
            <TextView
                android:id="@+id/viewImageText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="View Image"
                android:textColor="@color/primary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground" />
        </LinearLayout>

        <!-- Right Text Content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:orientation="vertical">

            <!-- Title -->
            <TextView
                android:id="@+id/historyAlert"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Durian Fall Detected!"
                android:textColor="#1B5E20"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- Info Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/historyTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🕒 02:15 PM"
                    android:textColor="#757575"
                    android:textSize="12sp" />
                <View
                    android:layout_width="1dp"
                    android:layout_height="14dp"
                    android:background="#E0E0E0"
                    android:layout_marginHorizontal="6dp" />

                <TextView
                    android:id="@+id/historyRegion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍 West Region"
                    android:textColor="#757575"
                    android:textSize="12sp" />
                <View
                    android:layout_width="1dp"
                    android:layout_height="14dp"
                    android:background="#E0E0E0"
                    android:layout_marginHorizontal="6dp" />

                <TextView
                    android:id="@+id/historyOrchard"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌳 Orchard A"
                    android:textColor="#757575"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="8dp"
                android:background="@color/divider" />

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:gravity="center">

                <TextView
                    android:id="@+id/collectButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Collect"
                    android:textColor="@color/primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="20dp"
                    android:background="@color/divider" />

                <TextView
                    android:id="@+id/deleteButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Delete"
                    android:textColor="@color/status_error"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>